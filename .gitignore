# ============================================================
# Openclaw Librarian Agent - .gitignore
# ============================================================

# ---- Sensitive / Environment ----
.env
.env.local
.env.*.local
.envrc
spec/LIBRARIES.md

# ---- Elixir / Erlang ----
/_build/
/deps/
/*.ez
/cover/
erl_crash.dump
*.beam
*.plt
*.plt.hash
doc/
.elixir_ls/
.lexical/
priv/plts/

# ---- Database ----
*.db
*.sqlite3
*.sqlite3-journal
/priv/data/

# ---- Docker ----
docker-compose.override.yml

# ---- OS files ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ---- IDE / Editor ----
.idea/
.vscode/
*.iml
.cursorignore
.cursorindexingignore

# ---- Logs ----
*.log
/logs/

# ---- Node (if any tooling) ----
node_modules/

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
dist/

# ---- Openclaw Runtime ----
.openclaw/
USER.md
/inbox/

# ---- Input folder contents ----
/input/*
!/input/.gitkeep

# ---- Processed folder contents ----
/processed/*
!/processed/.gitkeep

# ---- Temporary / Runtime ----
/tmp/
/.cache/

# ---- Agent Memory Logs (operational state, not code) ----
/memory/*
!/memory/.gitkeep
