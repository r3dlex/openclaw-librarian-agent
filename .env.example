# ============================================================
# Openclaw Librarian Agent - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ---- Vault (Obsidian-compatible) ----
# Absolute path to the Obsidian vault where documents are stored.
LIBRARIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ---- Data Folder ----
# Absolute path to the Librarian's working data folder.
# Contains: input/, logs/, and runtime data.
LIBRARIAN_DATA_FOLDER=/path/to/your/data/folder

# ---- Openclaw ----
# API key for the AI provider used by the Librarian agent.
OPENCLAW_PROVIDER_API_KEY=sk-your-api-key-here

# ---- Database ----
# Path to the SQLite database used for document indexing.
# Defaults to ${LIBRARIAN_DATA_FOLDER}/librarian.db if unset.
LIBRARIAN_DB_PATH=

# ---- Logging ----
# Log level: debug | info | warning | error
LIBRARIAN_LOG_LEVEL=info
