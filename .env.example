# ============================================================
# Openclaw Librarian Agent - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ---- Vault (Obsidian-compatible) ----
# Absolute path to the Obsidian vault where documents are stored.
LIBRARIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ---- Data Folder ----
# Primary data folder (single host path). Used for Docker volume mount.
# This is where staging/, log/, backups/, and DB live.
LIBRARIAN_PRIMARY_DATA_FOLDER=/path/to/your/primary/data/folder

# Comma-separated list of ALL data folder paths (host paths).
# First value is the primary. Each data folder gets input/ and processed/.
# Docker-compose overrides this inside the container with container paths.
# Example: /primary/data,/secondary/project
LIBRARIAN_DATA_FOLDER=/path/to/your/data/folder

# ---- Input Paths ----
# Comma-separated list of additional input folder paths.
# The agent monitors all listed folders for new documents to process.
# $LIBRARIAN_DATA_FOLDER/input is always included automatically.
# Example: /project/input,/extra/incoming
LIBRARIAN_INPUT_PATHS=

# ---- Openclaw ----
# API key for the AI provider used by the Librarian agent.
OPENCLAW_PROVIDER_API_KEY=sk-your-api-key-here

# ---- Database ----
# Path to the SQLite database used for document indexing.
# Defaults to ${LIBRARIAN_DATA_FOLDER}/librarian.db if unset.
LIBRARIAN_DB_PATH=

# ---- Logging ----
# Log level: debug | info | warning | error
LIBRARIAN_LOG_LEVEL=info

# ---- Atlassian Integration ----
# Configure one or more Atlassian accounts using numbered variables.
# The Librarian pulls content on demand from Jira, Confluence, and
# Jira Product Discovery (JPD) via these accounts.
#
# Account 1
ATLASSIAN_1_LABEL=work
ATLASSIAN_1_URL=https://your-org.atlassian.net
ATLASSIAN_1_EMAIL=you@example.com
ATLASSIAN_1_TOKEN=your-api-token
#
# Account 2 (optional)
# ATLASSIAN_2_LABEL=client
# ATLASSIAN_2_URL=https://client-org.atlassian.net
# ATLASSIAN_2_EMAIL=you@client.com
# ATLASSIAN_2_TOKEN=another-api-token

# ---- Inter-Agent Message Queue (IAMQ) ----
# URL of the Openclaw IAMQ service for inter-agent communication.
# The Librarian registers as "librarian_agent", heartbeats every 2 min,
# and polls its inbox every 30 seconds.
IAMQ_URL=http://127.0.0.1:18790
# Absolute path to this agent's workspace (reported to IAMQ for discovery).
LIBRARIAN_WORKSPACE_PATH=/path/to/openclaw-librarian-agent
